# .npmrc
# 严格模式，防止幽灵依赖
node-linker=isolated

# 自动安装 peer dependencies
auto-install-peers=true

# 使用 workspace 模式（如果你的项目是 monorepo）
# link-workspace-packages=deep

# 锁定文件使用 pnpm 的格式
lockfile=true

# 提升 Tauri 相关的依赖，避免构建问题
public-hoist-pattern[]=*tauri*
public-hoist-pattern[]=@tauri-apps/*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*

# 保存精确版本（可选，如果你想要更严格的控制）
# save-exact=true